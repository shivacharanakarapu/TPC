                    </NavLink>
                </li>
                <li class="nav-item dropdown mb-0 primary-nav-item">
                    <a class="nav-link px-3 py-3 fw-bold text-dark dropdown-toggle" href="#" id="resourcesDropdown" role="button" data-bs-toggle="dropdown">
                        RESOURCES
                    </a>
                    @* Dropdown content here *@
                </li>
            </ul>
        </div>
    </div>
</nav>