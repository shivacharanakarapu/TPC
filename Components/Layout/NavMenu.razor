@* Official State Banner *@
<div class="container-fluid py-4 px-4 text-white state-banner" style="background-color: #00415B;">
    @* Using a standard container ensures alignment with the dropdown below *@
    <div class="container">
        <div class="d-flex align-items-center" style="font-size: 0.99rem;">

            @* Clickable State Link *@
            <a href="https://delaware.gov/" class="text-white text-decoration-none d-flex align-items-center me-2">
                <img src="https://governor.delaware.gov/wp-content/themes/dosgic_LIGHTHOUSE_theme/assets/img/state-of-delaware-logo.gif"
                     alt="State of Delaware"
                     style="height: 2.2rem;"
                     class="me-4">
                
            </a>

            <span class="d-none d-md-inline ms-2">An official State of Delaware site.</span>

        <button class="btn btn-link text-white text-decoration-underline p-0 ms-1 banner-toggle-btn"
                    @onclick="ToggleBanner"
                    aria-expanded="@isBannerOpen"
                    aria-controls="bannerDetails">
                <b>
                Here's how you know
                </b><i class="bi @(isBannerOpen ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </button>
        </div>
    </div>
</div>



@* Expandable "How you know" Section *@
@if (isBannerOpen)
{
    <div class="container-fluid py-5 border-top border-secondary banner-expand" style="background-color: #00415B;">
        @* Remove 'justify-content-center' to align everything to the left *@
        <div class="container ms-4">
            <div class="row text-start">
                <div class="col-12">

                    @* Top Item: .gov info *@
                    <div class="d-flex align-items-start mb-4">
                        <i class="bi bi-bank2 me-3 fs-4 text-white"></i>
                        <div>
                            <h3 class="h6 fw-bold mb-3">Official websites end in .gov</h3>
                            <p class="mb-0">A .gov website belongs to an official government organization in the United States.</p>
                        </div>
                    </div>

                    @* Bottom Item: https:// info *@
                    <div class="d-flex align-items-start">
                        <i class="bi bi-lock-fill me-3 fs-4 text-white"></i>
                        <div>
                            <h3 class="h6 fw-bold mb-3">Secure .gov websites use https://</h3>
                            <p class="mb-0">
                                The https:// at the beginning of the delaware.gov address means you are safely connected to the government website.
                                Any information that you provide is securely transmitted.
                            </p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isBannerOpen = false;

    private void ToggleBanner()
    {
        isBannerOpen = !isBannerOpen;
    }
}

@* 2. Agency Header with Search *@
<div class="container-fluid d-flex justify-content-between align-items-center py-3 px-3 bg-white">
    <div class="d-flex align-items-center">
        <img src="https://dnrec.delaware.gov/wp-content/themes/dosgic_DNREC_theme/img/dnrec-logo-mark.png" height="50" width="50" class="me-3" />
        <h1 class="h4 mb-0 fw-semibold">Tax Parcel Change Utility</h1>
    </div>
    <div class="d-flex align-items-stretch" style="width: 340px;">
        <input type="text" class="form-control form-control-sm rounded-0" placeholder="Search this site..." style="font-size: 0.85rem;">
        <button class="btn btn-sm btn-primary-delaware rounded-0 text-white px-2 d-flex align-items-center text-nowrap" style="font-size: 0.85rem;">
            <i class="bi bi-search" style="width: auto; height: auto; margin-right: 0.3rem;"></i> Search
        </button>
    </div>
</div>

